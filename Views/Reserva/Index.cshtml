@* Asegúrate de que este sea el nombre correcto de tu DTO para Reservas *@
@model IEnumerable<SportReserva.Models.DTOs.ReservaDTO>
@{ 
    ViewData["Title"] = "Consultar Reservas"; 
}

<div class="container mt-4">
    <h2>Consultar Reservas</h2>

    <table class="table table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Fecha y Hora Registro</th>
                <th>Fecha Reservada</th>
                <th>Precio Total</th>
                <th>Estado</th>
                @if (User.IsInRole("Empresa"))
                {
                    <th>Acciones</th>
                }
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any()) {
                <tr><td colspan="@(User.IsInRole("Empresa") ? 6 : 5)" class="text-center">No hay reservas para mostrar.</td></tr>
            }
            @foreach(var item in Model) {
            <tr>
                <td>@item.IdReserva</td>
                <td>@item.FechaRegistro.ToString("g")</td>
                <td>@item.FechaReserva.ToShortDateString()</td>
                <td>S/ @item.PrecioTotal.ToString("0.00")</td>
                <td><span class="badge bg-info">@item.EstadoReserva</span></td>
                @if (User.IsInRole("Empresa"))
                {
                <td>
                    <form asp-action="Confirm" asp-route-id="@item.IdReserva" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-success" @(item.EstadoReserva == "Pendiente" ? "" : "disabled")>Confirmar</button>
                    </form>
                    <form asp-action="Cancel" asp-route-id="@item.IdReserva" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-danger" @(item.EstadoReserva == "Pendiente" ? "" : "disabled")>Cancelar</button>
                    </form>
                </td>
                }
            </tr>
            }
        </tbody>
    </table>
</div>