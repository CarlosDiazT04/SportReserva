@model SportReserva.Models.DTOs.CanchaDTO
@{
    ViewData["Title"] = "Crear Cancha";
}

<div class="container mt-4">
    <h2 class="mb-4 fw-bold text-uppercase"><i class="fa-solid fa-plus me-2"></i> Crear Nueva Cancha</h2>

    <div class="card shadow border-0 rounded-3">
        <div class="card-body p-4">
            <form asp-action="CrearCancha" asp-controller="Empresa" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Nombre" class="form-label fw-bold"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="TipoDeporte" class="form-label fw-bold"></label>
                    <input asp-for="TipoDeporte" class="form-control" />
                    <span asp-validation-for="TipoDeporte" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PrecioHora" class="form-label fw-bold"></label>
                    <input asp-for="PrecioHora" class="form-control" type="number" min="0" step="0.01" />
                    <span asp-validation-for="PrecioHora" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Estado" class="form-label fw-bold"></label>
                    <select asp-for="Estado" class="form-select">
                        <option value="Disponible">Disponible</option>
                        <option value="Mantenimiento">Mantenimiento</option>
                        <option value="Inactivo">Inactivo</option>
                    </select>
                    <span asp-validation-for="Estado" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Descripcion" class="form-label fw-bold"></label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="MisCanchas" asp-controller="Empresa" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-success">Guardar Cancha</button>
                </div>
            </form>
        </div>
    </div>
</div>
