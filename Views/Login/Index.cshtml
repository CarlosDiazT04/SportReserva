@model IEnumerable<SportReserva.Models.Entities.Cliente>
@{
    ViewData["Title"] = "Gestión de Clientes";
}

<div class="container mt-4">
    <h2 class="text-uppercase fw-bold"><i class="fa-solid fa-users text-success me-2"></i>Directorio de Clientes</h2>
    <p class="text-muted">Lista completa de clientes registrados en el sistema.</p>

    <div class="table-responsive mt-4">
        <table class="table table-hover shadow-sm bg-white border">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Nombres y Apellidos</th>
                    <th>DNI</th>
                    <th>Teléfono</th>
                    <th>Correo</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center py-4 text-muted">No hay clientes registrados.</td></tr>
                }
                else
                {
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td class="fw-bold">@c.IdCliente</td>
                            <td>@c.Nombres @c.Apellidos</td>
                            <td>@c.DNI</td>
                            <td>@c.Telefono</td>
                            <td>@c.Correo</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>