@model SportReserva.Models.DTOs.LoginDTO
@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="container mt-5" style="max-width: 450px;">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-white border-0 pt-4 pb-2 text-center rounded-top-4">
            <h4 class="fw-bold text-uppercase text-success"><i class="fa-solid fa-right-to-bracket me-2"></i>Iniciar Sesión</h4>
            <p class="text-muted">Ingresa a tu cuenta para reservar canchas.</p>
        </div>
        <div class="card-body p-4">
            <form asp-action="Index" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                
                <div class="mb-3">
                    <label asp-for="NombreUsuario" class="form-label fw-bold small text-uppercase">Usuario</label>
                    <input asp-for="NombreUsuario" class="form-control" required />
                </div>
                
                <div class="mb-4">
                    <label asp-for="Clave" class="form-label fw-bold small text-uppercase">Contraseña</label>
                    <input asp-for="Clave" type="password" class="form-control" required />
                </div>

                <button type="submit" class="btn btn-success fw-bold w-100 py-2 mb-3">Ingresar</button>
                
                <div class="text-center">
                    <p class="mb-0 text-muted small">¿No tienes cuenta? <a asp-action="Registro" class="text-success fw-bold text-decoration-none">Regístrate aquí</a></p>
                </div>
            </form>
        </div>
    </div>
</div>