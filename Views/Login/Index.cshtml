@model SportReserva.Models.DTOs.LoginDTO
@{ 
    ViewData["Title"] = "Iniciar Sesión"; 
}

<div class="container mt-5" style="max-width: 400px;">
    <h2 class="text-center mb-4">Iniciar Sesión</h2>
    <form asp-action="Index" method="post">
        <div class="form-group mb-3">
            <label asp-for="NombreUsuario" class="form-label">Usuario</label>
            <input asp-for="NombreUsuario" class="form-control" placeholder="Ingrese su usuario" required />
        </div>
        <div class="form-group mb-4">
            <label asp-for="Clave" class="form-label">Contraseña</label>
            <input asp-for="Clave" type="password" class="form-control" placeholder="Ingrese su contraseña" required />
        </div>
        <button type="submit" class="btn btn-primary w-100">Ingresar</button>
    </form>
</div>