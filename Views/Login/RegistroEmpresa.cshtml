@model SportReserva.Models.DTOs.RegistroEmpresaDTO
@{
    ViewData["Title"] = "Registro de Empresa";
}

<div class="container mt-5" style="max-width: 650px;">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-white border-0 pt-4 pb-2 text-center rounded-top-4">
            <h4 class="fw-bold text-uppercase text-primary"><i class="fa-solid fa-building me-2"></i>Registrar Empresa</h4>
            <p class="text-muted">Registra tu complejo deportivo y administra tus canchas.</p>
        </div>
        <div class="card-body p-4">
            <form asp-action="RegistroEmpresa" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <h6 class="fw-bold text-muted text-uppercase mb-3 border-bottom pb-2">Datos de Acceso</h6>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="NombreUsuario" class="form-label fw-bold small">Usuario de Empresa</label>
                        <input asp-for="NombreUsuario" class="form-control" placeholder="Ej: micomplejo" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Clave" class="form-label fw-bold small">Contraseña</label>
                        <input asp-for="Clave" type="password" class="form-control" required />
                    </div>
                </div>

                <h6 class="fw-bold text-muted text-uppercase mb-3 mt-4 border-bottom pb-2">Datos del Complejo Deportivo</h6>
                <div class="mb-3">
                    <label asp-for="Nombre" class="form-label fw-bold small">Nombre de la Empresa</label>
                    <input asp-for="Nombre" type="text" class="form-control" placeholder="Ej: Empresa Deportiva" required />
                </div>
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="RUC" class="form-label fw-bold small">RUC</label>
                        <input asp-for="RUC" type="text" class="form-control" placeholder="Ej: 20345678912" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Telefono" class="form-label fw-bold small">Teléfono</label>
                        <input asp-for="Telefono" type="text" class="form-control" placeholder="Ej: 999-999-999" />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Direccion" class="form-label fw-bold small">Dirección</label>
                    <input asp-for="Direccion" type="text" class="form-control" placeholder="Av. Principal 123" required />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label asp-for="UrlMapa" class="form-label fw-bold small">URL de Google Maps (Opcional)</label>
                        <input asp-for="UrlMapa" type="text" class="form-control" placeholder="Ej: https://maps.app.goo.gl/..." />
                    </div>
                    <div class="col-md-6 mb-4">
                        <label asp-for="UrlQR" class="form-label fw-bold small">Enlace del QR (Yape/Plin)</label>
                        <input asp-for="UrlQR" type="text" class="form-control" placeholder="URL de la imagen de tu QR" />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary fw-bold w-100 py-2 mb-2">Completar Registro</button>
                <a asp-action="Index" class="btn btn-outline-secondary fw-bold w-100 py-2">Volver al Inicio de Sesión</a>
            </form>
        </div>
    </div>
</div>