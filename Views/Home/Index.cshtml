@{
    ViewData["Title"] = "Inicio";
}

<div class="container mt-5">
    <div class="row align-items-center">
        <div class="col-lg-6 text-center text-lg-start mb-5 mb-lg-0">
            <h1 class="display-4 fw-bold text-success mb-3">SportReserva</h1>
            <h2 class="h3 text-muted mb-4">Una nueva forma de reservar canchas deportivas</h2>
            <p class="lead mb-4">
                Encuentra tu cancha ideal para jugar con amigos o registra tu complejo deportivo para llegar a más jugadores. ¡Únete a nuestra comunidad!
            </p>
            <div class="d-grid gap-3 d-sm-flex justify-content-sm-center justify-content-lg-start">
                <a href="@Url.Action("Index", "Login")" class="btn btn-primary btn-lg px-4 gap-3 fw-bold">Iniciar Sesión</a>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5 text-center">
                    <h3 class="fw-bold mb-4">¿Eres nuevo aquí?</h3>
                    <p class="text-muted mb-4">Elige cómo deseas registrarte para comenzar a disfrutar de nuestros servicios.</p>
                    
                    <div class="d-grid gap-3">
                        <a href="@Url.Action("Registro", "Login")" class="btn btn-outline-success btn-lg fw-bold">
                            <i class="fa-solid fa-user me-2"></i>Registrarme como Jugador
                        </a>
                        <a href="@Url.Action("RegistroEmpresa", "Login")" class="btn btn-outline-primary btn-lg fw-bold">
                            <i class="fa-solid fa-building me-2"></i>Registrar mi Complejo / Cancha
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5 pt-5 text-center">
        <div class="col-md-4 mb-4">
            <div class="p-3">
                <i class="fa-solid fa-futbol fa-3x text-success mb-3"></i>
                <h4 class="fw-bold">Variedad de Deportes</h4>
                <p class="text-muted">Fútbol, básquet, tenis y más. Encuentra la cancha perfecta para tu deporte favorito.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="p-3">
                <i class="fa-solid fa-clock fa-3x text-success mb-3"></i>
                <h4 class="fw-bold">Reserva al Instante</h4>
                <p class="text-muted">Consulta disponibilidad en tiempo real y asegura tu turno en cuestión de segundos.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="p-3">
                <i class="fa-solid fa-chart-line fa-3x text-success mb-3"></i>
                <h4 class="fw-bold">Potencia tu Negocio</h4>
                <p class="text-muted">Si tienes canchas, adminístralas fácilmente y aumenta tus ingresos alquilándolas aquí.</p>
            </div>
        </div>
    </div>
</div>