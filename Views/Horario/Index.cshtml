@model dynamic
@{
    ViewData["Title"] = "Gestión de Horarios";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-uppercase mb-0"><i class="fa-regular fa-clock me-2"></i> Gestión de Horarios</h2>
    <a asp-action="Create" class="btn btn-success"><i class="fa-solid fa-plus me-1"></i> Nuevo Horario</a>
</div>

    <div class="table-responsive">
        <table class="table table-striped table-hover shadow-sm border rounded">
            <thead class="table-dark">
                <tr>
                    <th>ID Horario</th>
                    <th>Hora de Inicio</th>
                    <th>Hora de Fin</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    @foreach (var horario in Model)
                    {
                        <tr>
                            <td>@horario.IdHorario</td>
                            <td>@horario.HoraInicio</td>
                            <td>@horario.HoraFin</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-3">No hay horarios registrados aún.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>